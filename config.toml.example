[discord]
bot_token = "${DISCORD_BOT_TOKEN}"
allowed_channels = ["1234567890"]
# allowed_user_id, when set, takes precedence over allowed_channels —
# the bot will only respond to these Discord user IDs (in any channel).
# Use ["*"] as a wildcard to allow any user from any channel.
# allowed_user_id = ["111111111111111111"]
# allowed_user_id = ["*"]

[discord.reactions]
enabled = true
remove_after_reply = false
# tool_display controls how ACP tool-call lines are rendered in the streaming
# message. One of: "full" (original title), "compact" (first token — default),
# or "none" (hide tool lines entirely). Use "compact" or "none" when agents
# put full shell commands in tool titles (e.g. codex), to avoid long noisy
# lines and accidental exposure of URLs/paths/args in public channels.
# tool_display = "compact"

[discord.reactions.emojis]
queued = "👀"
thinking = "🤔"
tool = "🔥"
coding = "👨💻"
web = "⚡"
done = "🆗"
error = "😱"

[discord.reactions.timing]
debounce_ms = 700
stall_soft_ms = 10000
stall_hard_ms = 30000
done_hold_ms = 1500
error_hold_ms = 2500

# [telegram]
# bot_token = "${TELEGRAM_BOT_TOKEN}"
# allowed_chats = [-100123456789]
# allowed_user_id, when set, takes precedence over allowed_chats —
# the bot will only respond to these Telegram user IDs (in any chat).
# IDs are strings so that ["*"] (wildcard) can coexist with numeric IDs.
# Use ["*"] as a wildcard to allow any user from any chat.
# allowed_user_id = ["123456789"]
# allowed_user_id = ["*"]

# [telegram.reactions]
# enabled = true
# remove_after_reply = false
# tool_display = "compact"   # full | compact | none — see [discord.reactions] above

# [telegram.reactions.emojis]
# queued = "👌"
# thinking = "🤔"
# tool = "🔥"
# coding = "🤓"
# web = "⚡"
# done = "👍"
# error = "😱"

# [telegram.reactions.timing]
# debounce_ms = 700
# stall_soft_ms = 10000
# stall_hard_ms = 30000
# done_hold_ms = 1500
# error_hold_ms = 2500

# [teams]
# app_id = "${TEAMS_APP_ID}"
# app_secret = "${TEAMS_APP_SECRET}"
# tenant_id = "${TEAMS_TENANT_ID}"
# listen = ":3978"
# allowed_channels = ["19:abc123@thread.tacv2"]
# allowed_user_id, when set, takes precedence over allowed_channels —
# the bot will only respond to these Teams user IDs (in any conversation).
# Use ["*"] as a wildcard to allow any user.
# allowed_user_id = ["29:user-object-id"]
# allowed_user_id = ["*"]
# tool_display = "compact"   # full | compact | none — see [discord.reactions] above

[agent]
command = "kiro-cli"
args = ["acp", "--trust-all-tools"]
working_dir = "/home/agent"

# [agent]
# command = "claude-agent-acp"
# args = []
# working_dir = "/home/node"
# env = { ANTHROPIC_API_KEY = "${ANTHROPIC_API_KEY}" }

# [agent]
# command = "codex-acp"
# args = []
# working_dir = "/home/node"
# env = { OPENAI_API_KEY = "${OPENAI_API_KEY}" }

# [agent]
# command = "copilot"
# args = ["--acp", "--stdio"]
# working_dir = "/home/node"
# env = {}  # Auth via: kubectl exec -it <pod> -- gh auth login -p https -w

# [agent]
# command = "gemini"
# args = ["--experimental-acp"]
# working_dir = "/home/node"
# env = { GEMINI_API_KEY = "${GEMINI_API_KEY}" }  # or run `gemini` once to OAuth

[pool]
max_sessions = 10
session_ttl_hours = 24

# Markdown rewrite pipeline applied to LLM replies before they are sent
# to a chat platform. Discord and Telegram both ignore GFM table syntax,
# so the bot reformats tables for readable rendering.
#
# tables = "code"     wrap each table in a fenced ``` block (default)
# tables = "bullets"  convert each row into "• Header: Value" bullet lines
# tables = "off"      pass through, no conversion
# [markdown]
# tables = "code"

# HTTP API for session monitoring (optional)
# [api]
# enabled = true
# listen = ":8080"

# STT - Speech-to-Text (optional)
# Set api_key to enable voice message transcription via OpenAI Whisper
# [stt]
# api_key = "${OPENAI_API_KEY}"
# provider = "openai"
# model = "whisper-1"
# language = "zh"
# prompt = "以下是繁體中文語音的逐字稿："
# base_url = "https://api.openai.com/v1"

# TTS - Text-to-Speech (optional)
# Bot replies with voice when user sends a voice message.
# provider = "openai" (default) or "gemini"

# OpenAI TTS:
# [tts]
# provider = "openai"
# api_key = "${OPENAI_API_KEY}"
# model = "tts-1"              # or "tts-1-hd", "gpt-4o-mini-tts"
# voice = "nova"               # alloy, ash, ballad, coral, echo, fable, nova, onyx, sage, shimmer
# instructions = ""            # voice style instructions (gpt-4o-mini-tts only)
# base_url = "https://api.openai.com/v1"

# Gemini TTS (female voice):
# [tts]
# provider = "gemini"
# api_key = "${GEMINI_API_KEY}"
# model = "gemini-3.1-flash-tts-preview"   # or gemini-2.5-flash-preview-tts, gemini-2.5-pro-preview-tts
# voice = "Kore"               # Kore (Firm, Middle pitch)
# style = "vocal_smile"        # vocal_smile, newscaster, whisper, empathetic, promo_hype, deadpan
# instructions = ""            # custom tone/style instruction (combined with style if both set)
# style_prefix = "[shy]"       # emotion tag prepended to each line (Gemini only)
# style_suffix = "[laughs softly]"  # emotion tag appended to each line (Gemini only)

# Gemini TTS (male voice):
# [tts]
# provider = "gemini"
# api_key = "${GEMINI_API_KEY}"
# model = "gemini-3.1-flash-tts-preview"
# voice = "Orus"               # Orus (Firm, Lower middle pitch)
